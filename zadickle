-- ══════════════════════════════════════════
--  LÓGICA PRINCIPAL DE CARGA
-- ══════════════════════════════════════════
local startTime   = tick()
local elapsed     = 0
local lastDotSwap = 0
local lastSubSwap = 0
local activeDot   = 1
local finished    = false
 
local connection
connection = RunService.Heartbeat:Connect(function(dt)
    if finished then return end
 
    elapsed = tick() - startTime
    local progress = math.clamp(elapsed / LOAD_DURATION, 0, 1)
    local pct      = math.floor(progress * 100)
 
    -- Barra de progreso (suavizada con easing)
    local easedProg = 1 - (1 - progress)^2.5    -- ease-out
    BarFill.Size    = UDim2.new(easedProg, 0, 1, 0)
 
    -- Porcentaje
    PctLabel.Text   = pct .. "%"
 
    -- Timer (cuenta hacia arriba)
    local mins = math.floor(elapsed / 60)
    local secs = math.floor(elapsed % 60)
    TimerLabel.Text = string.format("%02d:%02d", mins, secs)
 
    -- Rotar subtítulo cada ~2 segundos
    if elapsed - lastSubSwap >= 2 then
        lastSubSwap = elapsed
        subIndex    = (subIndex % #subTexts) + 1
        local tw = TweenService:Create(
            SubTitle,
            TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            { TextTransparency = 1 }
        )
        tw:Play()
        tw.Completed:Connect(function()
            SubTitle.Text = subTexts[subIndex]
            TweenService:Create(
                SubTitle,
                TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                { TextTransparency = 0 }
            ):Play()
        end)
    end
 
    -- Rotar dot activo cada ~1.5 segundos
    if elapsed - lastDotSwap >= 1.5 then
        lastDotSwap  = elapsed
        local prevDot = activeDot
        activeDot     = (activeDot % 3) + 1
        TweenService:Create(
            dots[prevDot],
            TweenInfo.new(0.3, Enum.EasingStyle.Quad),
            { BackgroundColor3 = C_DOT_INACTIVE }
        ):Play()
        TweenService:Create(
            dots[activeDot],
            TweenInfo.new(0.3, Enum.EasingStyle.Quad),
            { BackgroundColor3 = C_DOT_ACTIVE }
        ):Play()
    end
 
    -- Al completar
    if progress >= 1 then
        finished = true
        connection:Disconnect()
        pulseTween:Cancel()
 
        task.delay(0.4, function()
            -- Barra al 100%
            TweenService:Create(
                BarFill,
                TweenInfo.new(0.3, Enum.EasingStyle.Quad),
                { Size = UDim2.new(1, 0, 1, 0) }
            ):Play()
            PctLabel.Text   = "100%"
 
            task.delay(0.5, function()
                -- Fade out de todo
                local tweenInfo = TweenInfo.new(FADE_OUT_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
                local targets = {
                    { Card,         "BackgroundTransparency", 1 },
                    { CardStroke,   "Transparency",           1 },
                    { Overlay,      "BackgroundTransparency", 1 },
                    { NameLabel,    "TextTransparency",       1 },
                    { SubNameLabel, "TextTransparency",       1 },
                    { LoadTitle,    "TextTransparency",       1 },
                    { SubTitle,     "TextTransparency",       1 },
                    { TimerLabel,   "TextTransparency",       1 },
                    { PctLabel,     "TextTransparency",       1 },
                    { Footer,       "TextTransparency",       1 },
                    { AvatarImg,    "ImageTransparency",      1 },
                    { BarBG,        "BackgroundTransparency", 1 },
                    { BarFill,      "BackgroundTransparency", 1 },
                    { Divider,      "BackgroundTransparency", 1 },
                }
                for _, t in ipairs(targets) do
                    TweenService:Create(t[1], tweenInfo, { [t[2]] = t[3] }):Play()
                end
                for _, dot in ipairs(dots) do
                    TweenService:Create(dot, tweenInfo, { BackgroundTransparency = 1 }):Play()
                end
                -- Destruir después del fade
                task.delay(FADE_OUT_TIME + 0.1, function()
                    ScreenGui:Destroy()
                end)
            end)
        end)
    end
end)
