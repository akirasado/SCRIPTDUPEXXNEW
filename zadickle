local function fadeIn(obj, prop, target, delay_)
    task.delay(delay_ or 0, function()
        TweenService:Create(obj, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {[prop] = target}):Play()
    end)
end
 
