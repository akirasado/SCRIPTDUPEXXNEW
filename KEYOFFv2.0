-- ============================================================
--  DUPEXX GALATIC SCRIPT — LOADING SCREEN v2.0
--  Ultra-cinematic space loading screen
--  Inspirado en Interstellar | Sci-fi profundo
-- ============================================================

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local ContentProvider = game:GetService("ContentProvider")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- ============================================================
--  CONFIGURACIÓN
-- ============================================================
local CONFIG = {
	LOADING_TIME = 8,           -- segundos mínimos de carga
	STAR_COUNT = 180,
	NEBULA_COUNT = 4,
	BLACK_HOLE_PARTICLES = 220,
	JET_INTERVAL = 30,          -- segundos entre jets
	JET_PARTICLES = 40,
	GALAXY_ARMS = 2,
	GALAXY_POINTS = 90,
}

-- ============================================================
--  SETUP SCREENGUI
-- ============================================================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "DupexxLoadingScreen"
screenGui.IgnoreGuiInset = true
screenGui.ResetOnSpawn = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.Parent = playerGui

local W = 1920
local H = 1080

-- Frame raíz (fondo negro profundo)
local root = Instance.new("Frame")
root.Name = "Root"
root.Size = UDim2.fromScale(1, 1)
root.Position = UDim2.fromScale(0, 0)
root.BackgroundColor3 = Color3.fromRGB(2, 3, 10)
root.BorderSizePixel = 0
root.ZIndex = 1
root.Parent = screenGui

-- ============================================================
--  UTILIDADES
-- ============================================================
local function lerp(a, b, t) return a + (b - a) * t end
local function rand(min, max) return min + math.random() * (max - min) end
local function randInt(min, max) return math.random(min, max) end
local function hsv(h, s, v) return Color3.fromHSV(h, s, v) end

local function createFrame(parent, size, pos, color, alpha, zindex)
	local f = Instance.new("Frame")
	f.Size = size
	f.Position = pos
	f.BackgroundColor3 = color or Color3.new(1,1,1)
	f.BackgroundTransparency = alpha or 0
	f.BorderSizePixel = 0
	f.ZIndex = zindex or 2
	f.Parent = parent
	return f
end

local function createImageLabel(parent, size, pos, zindex)
	local img = Instance.new("ImageLabel")
	img.Size = size
	img.Position = pos
	img.BackgroundTransparency = 1
	img.ZIndex = zindex or 2
	img.Parent = parent
	return img
end

local function createLabel(parent, text, size, pos, color, fontsize, zindex)
	local lbl = Instance.new("TextLabel")
	lbl.Size = size
	lbl.Position = pos
	lbl.BackgroundTransparency = 1
	lbl.Text = text
	lbl.TextColor3 = color or Color3.new(1,1,1)
	lbl.TextSize = fontsize or 18
	lbl.Font = Enum.Font.GothamBold
	lbl.ZIndex = zindex or 10
	lbl.Parent = parent
	return lbl
end

local function tween(obj, time, props, style, dir)
	local info = TweenInfo.new(
		time,
		style or Enum.EasingStyle.Sine,
		dir or Enum.EasingDirection.InOut
	)
	local t = TweenService:Create(obj, info, props)
	t:Play()
	return t
end

-- ============================================================
--  CAPA 1 — GRADIENTE CÓSMICO DE FONDO
-- ============================================================
do
	local grad = Instance.new("UIGradient")
	grad.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(2, 3, 10)),
		ColorSequenceKeypoint.new(0.3, Color3.fromRGB(4, 8, 28)),
		ColorSequenceKeypoint.new(0.7, Color3.fromRGB(8, 3, 20)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(2, 3, 10)),
	})
	grad.Rotation = 135
	grad.Parent = root
end

-- ============================================================
--  CAPA 2 — NEBULOSAS (4 capas sutiles)
-- ============================================================
local nebulas = {}
local nebulaData = {
	{color = Color3.fromRGB(20, 40, 120), x = 0.1, y = 0.15, w = 0.55, h = 0.55, rot = 0},
	{color = Color3.fromRGB(80, 15, 100), x = 0.45, y = 0.3, w = 0.6, h = 0.5, rot = 45},
	{color = Color3.fromRGB(15, 60, 130), x = 0.6, y = 0.05, w = 0.45, h = 0.45, rot = -20},
	{color = Color3.fromRGB(100, 10, 60), x = 0.0, y = 0.5, w = 0.4, h = 0.4, rot = 10},
}

for _, nd in ipairs(nebulaData) do
	local neb = Instance.new("Frame")
	neb.Size = UDim2.fromScale(nd.w, nd.h)
	neb.Position = UDim2.fromScale(nd.x - nd.w/2, nd.y - nd.h/2)
	neb.BackgroundColor3 = nd.color
	neb.BackgroundTransparency = 0.88
	neb.BorderSizePixel = 0
	neb.ZIndex = 2
	neb.Parent = root

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(1, 0)
	corner.Parent = neb

	-- Blur simulado con gradiente radial
	local grad = Instance.new("UIGradient")
	grad.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
		ColorSequenceKeypoint.new(0.5, Color3.new(1,1,1)),
		ColorSequenceKeypoint.new(1, Color3.new(0,0,0)),
	})
	grad.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0),
		NumberSequenceKeypoint.new(0.6, 0.3),
		NumberSequenceKeypoint.new(1, 1),
	})
	grad.Rotation = nd.rot
	grad.Parent = neb

	table.insert(nebulas, {frame = neb, baseRot = nd.rot, speed = rand(0.3, 0.8)})
end

-- ============================================================
--  CAPA 3 — ESTRELLAS (campo dinámico)
-- ============================================================
local stars = {}
local starLayer = createFrame(root, UDim2.fromScale(1,1), UDim2.fromScale(0,0), Color3.new(0,0,0), 1, 3)

for i = 1, CONFIG.STAR_COUNT do
	local size = rand(1, 3.5)
	local x = rand(0, 1)
	local y = rand(0, 1)
	local brightness = rand(0.5, 1)
	local blinkSpeed = rand(1.5, 5.0)
	local blinkOffset = rand(0, math.pi * 2)

	local star = Instance.new("Frame")
	star.Size = UDim2.fromOffset(size, size)
	star.Position = UDim2.fromScale(x, y)
	star.AnchorPoint = Vector2.new(0.5, 0.5)
	star.BackgroundColor3 = Color3.fromRGB(
		randInt(200, 255),
		randInt(200, 255),
		randInt(220, 255)
	)
	star.BackgroundTransparency = 1 - brightness * 0.8
	star.BorderSizePixel = 0
	star.ZIndex = 3
	star.Parent = starLayer

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(1,0)
	corner.Parent = star

	table.insert(stars, {
		frame = star,
		baseAlpha = 1 - brightness * 0.8,
		blinkSpeed = blinkSpeed,
		blinkOffset = blinkOffset,
		x = x, y = y,
		lifeTime = rand(8, 20),
		age = rand(0, 20),
	})
end

-- ============================================================
--  CAPA 4 — GALAXIA ESPIRAL (esquina superior derecha)
-- ============================================================
local galaxyContainer = createFrame(root, UDim2.fromOffset(220, 220), UDim2.new(1, -240, 0, 20), Color3.new(0,0,0), 1, 4)
local galaxyPoints = {}

for arm = 0, CONFIG.GALAXY_ARMS - 1 do
	for i = 1, CONFIG.GALAXY_POINTS do
		local t = i / CONFIG.GALAXY_POINTS
		local angle = (arm / CONFIG.GALAXY_ARMS) * math.pi * 2 + t * math.pi * 3
		local radius = t * 95
		local noise = rand(-6, 6)
		local px = 110 + math.cos(angle) * (radius + noise)
		local py = 110 + math.sin(angle) * (radius + noise) * 0.45

		local brightness = lerp(1, 0.1, t)
		local size = lerp(3, 1, t)
		local colorMix = rand(0, 1)

		local pt = Instance.new("Frame")
		pt.Size = UDim2.fromOffset(size, size)
		pt.Position = UDim2.fromOffset(px - size/2, py - size/2)
		pt.AnchorPoint = Vector2.new(0.5, 0.5)
		pt.BackgroundTransparency = 1 - brightness * 0.9

		if colorMix > 0.6 then
			pt.BackgroundColor3 = Color3.fromRGB(180, 160, 255)
		elseif colorMix > 0.3 then
			pt.BackgroundColor3 = Color3.fromRGB(255, 240, 200)
		else
			pt.BackgroundColor3 = Color3.fromRGB(150, 200, 255)
		end

		pt.BorderSizePixel = 0
		pt.ZIndex = 4
		pt.Parent = galaxyContainer

		local c = Instance.new("UICorner")
		c.CornerRadius = UDim.new(1,0)
		c.Parent = pt

		table.insert(galaxyPoints, pt)
	end
end

