-- ============================================================
--  TYPING EFFECT
-- ============================================================
local PHASES = {
	{text = "LOADING DUPEXX GALATIC SCRIPT", sub = "Initializing galactic systems...", color = Color3.fromRGB(180,60,255), barColor = nil},
	{text = "INJECTING MODULES", sub = "Deploying cosmic payload...", color = Color3.fromRGB(60, 220, 120), barColor = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 180, 80)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(60, 220, 120)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(100, 255, 180)),
	})},
}

local currentPhase = 1
local typingDone = false

local function typeWrite(label, text, speed)
	typingDone = false
	label.Text = ""
	for i = 1, #text do
		label.Text = string.sub(text, 1, i)
		task.wait(speed or 0.04)
	end
	typingDone = true
end

-- ============================================================
--  ANIMACIÓN PRINCIPAL (RenderStepped)
-- ============================================================
local startTime = tick()
local progress = 0
local galaxyAngle = 0
local lastJet = tick()

local renderConn
renderConn = RunService.RenderStepped:Connect(function(dt)
	local t = tick()
	local elapsed = t - startTime
	galaxyAngle = galaxyAngle + dt * 0.18

	-- Progreso de carga suavizado
	local targetProgress = math.min(elapsed / CONFIG.LOADING_TIME, 1)
	progress = lerp(progress, targetProgress, dt * 2.5)

	-- Actualizar barra
	barFill.Size = UDim2.fromScale(progress, 1)
	percentLabel.Text = math.floor(progress * 100) .. "%"

	-- Cambio de fase al 50%
	if progress >= 0.5 and currentPhase == 1 then
		currentPhase = 2
		local ph = PHASES[2]
		if ph.barColor then
			fillGrad.Color = ph.barColor
		end
		titleLabel.TextColor3 = ph.color
		task.spawn(function()
			typeWrite(titleLabel, ph.text, 0.05)
		end)
		task.spawn(function()
			task.wait(0.3)
			phaseLabel.Text = ph.sub
		end)
	end

	-- Nebulosas: rotación lenta
	for _, nd in ipairs(nebulas) do
		local rotSpeed = nd.speed * 12
		local newRot = nd.baseRot + elapsed * rotSpeed
		-- No podemos rotar frames directamente, pero animamos posición ligeramente
		local wobble = math.sin(elapsed * nd.speed) * 0.005
		nd.frame.Position = UDim2.fromScale(
			nd.frame.Position.X.Scale + wobble * dt,
			nd.frame.Position.Y.Scale
		)
		-- Pulso de opacidad
		local pulse = 0.88 + math.sin(elapsed * nd.speed * 0.5) * 0.04
		nd.frame.BackgroundTransparency = pulse
	end

	-- Estrellas: parpadeo y reaparición
	for _, sd in ipairs(stars) do
		sd.age = sd.age + dt
		local lifeProgress = (sd.age % sd.lifeTime) / sd.lifeTime
		local blink = math.abs(math.sin(elapsed * sd.blinkSpeed + sd.blinkOffset))
		sd.frame.BackgroundTransparency = lerp(sd.baseAlpha, 1, 1 - blink)
		-- Reaparece en otro lugar al morir
		if lifeProgress > 0.98 then
			sd.x = rand(0, 1)
			sd.y = rand(0, 1)
			sd.frame.Position = UDim2.fromScale(sd.x, sd.y)
		end
	end

	-- Galaxia: rotación orbital
	galaxyContainer.Rotation = galaxyAngle * (180 / math.pi)

	-- Partículas del agujero negro
	for _, pd in ipairs(orbitParticles) do
		pd.angle = pd.angle + dt * pd.speed

		-- Trayectoria elíptica con curvatura gravitacional
		local rawX = math.cos(pd.angle) * pd.radius
		local rawY = math.sin(pd.angle) * pd.radius * pd.yScale

		-- Simular curvatura: partículas se "hunden" detrás
		local behind = math.sin(pd.angle) < 0
		local zFactor = behind and 0.85 or 1.0
		local px = 210 + rawX * zFactor
		local py = 210 + rawY * zFactor

		pd.frame.Position = UDim2.fromOffset(px - pd.size/2, py - pd.size/2)

		-- Transparencia basada en profundidad
		local depthAlpha = behind and rand(0.4, 0.7) or rand(0.05, 0.35)
		pd.frame.BackgroundTransparency = depthAlpha

		-- Tamaño varía con profundidad (perspectiva)
		local scaledSize = behind and pd.size * 0.7 or pd.size
		pd.frame.Size = UDim2.fromOffset(scaledSize, scaledSize)
		pd.frame.ZIndex = behind and 14 or 17
	end

	-- Jets cada 30 segundos
	if t - lastJet >= CONFIG.JET_INTERVAL then
		lastJet = t
		task.spawn(fireJet)
	end

	-- Glow del título (pulso)
	local glowPulse = (math.sin(elapsed * 2.5) + 1) / 2
	titleStroke.Transparency = lerp(0.1, 0.6, glowPulse)

	-- Shine en la barra
	local shinePos = (elapsed * 0.6) % 1.4 - 0.2
	shine.Position = UDim2.fromScale(shinePos, 0)

	-- Logo pulso
	local logoPulse = (math.sin(elapsed * 1.8) + 1) / 2
	listroke.Transparency = lerp(0.0, 0.5, logoPulse)

	-- Fin de carga
	if progress >= 0.999 then
		renderConn:Disconnect()
		task.wait(0.8)
		-- Fade out final
		tween(root, 1.2, {BackgroundTransparency = 1}, Enum.EasingStyle.Cubic, Enum.EasingDirection.In)
		for _, desc in ipairs(root:GetDescendants()) do
			if desc:IsA("Frame") or desc:IsA("TextLabel") or desc:IsA("ImageLabel") then
				pcall(function()
					tween(desc, 1.0, {BackgroundTransparency = 1}, Enum.EasingStyle.Cubic, Enum.EasingDirection.In)
					if desc:IsA("TextLabel") then
						tween(desc, 1.0, {TextTransparency = 1}, Enum.EasingStyle.Cubic, Enum.EasingDirection.In)
					end
				end)
			end
		end
		task.wait(1.5)
		screenGui:Destroy()
	end
end)

-- ============================================================
--  INICIO — Typing del título fase 1
-- ============================================================
task.spawn(function()
	task.wait(0.3)
	typeWrite(titleLabel, PHASES[1].text, 0.045)
	phaseLabel.Text = PHASES[1].sub
end)

-- Primer jet inmediato
task.spawn(function()
	task.wait(2)
	fireJet()
end)

-- ============================================================
--  FIN DEL SCRIPT
-- ============================================================
