	UDim2.new(bhCenterX, -210, bhCenterY, -210),
	Color3.new(0,0,0), 1, 5)

-- Anillo de sombra exterior (lente gravitacional)
for r = 1, 5 do
	local ring = Instance.new("Frame")
	local rs = bhRadius * 2 + r * 28
	ring.Size = UDim2.fromOffset(rs, rs * 0.42)
	ring.Position = UDim2.fromOffset(210 - rs/2, 210 - rs*0.42/2)
	ring.BackgroundColor3 = Color3.fromRGB(5, 10, 30)
	ring.BackgroundTransparency = lerp(0.3, 0.85, (r-1)/4)
	ring.BorderSizePixel = 0
	ring.ZIndex = 5
	ring.Parent = bhContainer
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(1,0)
	c.Parent = ring
end

-- Disco de acreción brillante
local discColors = {
	{Color3.fromRGB(255, 200, 80), 0.0},
	{Color3.fromRGB(255, 120, 30), 0.2},
	{Color3.fromRGB(200, 60, 180), 0.5},
	{Color3.fromRGB(100, 150, 255), 0.8},
	{Color3.fromRGB(200, 220, 255), 1.0},
}

for i = 1, 8 do
	local disc = Instance.new("Frame")
	local dw = bhRadius * 2 + i * 18
	local dh = dw * 0.20
	disc.Size = UDim2.fromOffset(dw, dh)
	disc.Position = UDim2.fromOffset(210 - dw/2, 210 - dh/2)
	local t = (i-1)/7
	local colorIdx = math.floor(t * (#discColors - 1)) + 1
	disc.BackgroundColor3 = discColors[math.min(colorIdx, #discColors)][1]
	disc.BackgroundTransparency = lerp(0.2, 0.75, t)
	disc.BorderSizePixel = 0
	disc.ZIndex = 5 + i
	disc.Parent = bhContainer
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(1,0)
	c.Parent = disc
end

