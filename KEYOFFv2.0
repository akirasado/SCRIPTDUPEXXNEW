-- ============================================================
--  PARTÍCULAS DEL DISCO DE ACRECIÓN
-- ============================================================
local orbitParticles = {}
local orbitLayer = createFrame(root, UDim2.fromOffset(420, 420),
	UDim2.new(bhCenterX, -210, bhCenterY, -210),
	Color3.new(0,0,0), 1, 14)

local particleColors = {
	Color3.fromRGB(255, 255, 255),
	Color3.fromRGB(255, 215, 80),
	Color3.fromRGB(120, 180, 255),
	Color3.fromRGB(200, 100, 255),
	Color3.fromRGB(255, 140, 50),
}

for i = 1, CONFIG.BLACK_HOLE_PARTICLES do
	local angle = (i / CONFIG.BLACK_HOLE_PARTICLES) * math.pi * 2
	local armSpread = rand(-0.4, 0.4)
	local orbitRadius = rand(bhRadius + 5, bhRadius + 90)
	local speed = rand(0.3, 1.2) * (1 / (orbitRadius / bhRadius))
	local size = rand(1.5, 4)
	local colorChoice = particleColors[randInt(1, #particleColors)]

	local pt = Instance.new("Frame")
	pt.Size = UDim2.fromOffset(size, size)
	pt.BackgroundColor3 = colorChoice
	pt.BackgroundTransparency = rand(0.0, 0.4)
	pt.BorderSizePixel = 0
	pt.ZIndex = 15
	pt.Parent = orbitLayer

	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(1,0)
	c.Parent = pt

	table.insert(orbitParticles, {
		frame = pt,
		angle = angle + armSpread,
		radius = orbitRadius,
		speed = speed,
		size = size,
		yScale = rand(0.15, 0.30),  -- achatamiento elíptico
	})
end

-- ============================================================
--  JETS (partículas polares cada 30s)
-- ============================================================
local jetParticles = {}
local jetLayer = createFrame(root, UDim2.fromOffset(420, 420),
	UDim2.new(bhCenterX, -210, bhCenterY, -210),
	Color3.new(0,0,0), 1, 16)

local function fireJet()
	for i = 1, CONFIG.JET_PARTICLES do
		local isTop = i <= CONFIG.JET_PARTICLES / 2
		local spread = rand(-18, 18)
		local speed = rand(40, 100)
		local life = rand(1.5, 3.5)

		local pt = Instance.new("Frame")
		pt.Size = UDim2.fromOffset(2, 2)
		pt.Position = UDim2.fromOffset(209 + spread, isTop and 210 - bhRadius or 210 + bhRadius)
		pt.BackgroundColor3 = Color3.fromRGB(220, 240, 255)
		pt.BackgroundTransparency = 0.1
		pt.BorderSizePixel = 0
		pt.ZIndex = 16
		pt.Parent = jetLayer

		local c = Instance.new("UICorner")
		c.CornerRadius = UDim.new(1,0)
		c.Parent = pt

		local direction = isTop and -1 or 1
		local targetY = pt.Position.Y.Offset + direction * speed
		local targetX = pt.Position.X.Offset + spread * 0.5

		tween(pt, life, {
			Position = UDim2.fromOffset(targetX, targetY),
			BackgroundTransparency = 1,
		}, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

		task.delay(life, function()
			if pt and pt.Parent then pt:Destroy() end
		end)
	end
end

