--// 🌌 GALAXIA ESPIRAL -----------------------
local galaxy = Instance.new("Frame")
galaxy.Size = UDim2.new(0,400,0,400)
galaxy.Position = UDim2.new(0.5,-200,0.5,-200)
galaxy.BackgroundTransparency = 1
galaxy.Parent = background

for i = 1,200 do
	local star = Instance.new("Frame")
	local angle = i * 0.3
	local radius = angle * 6

	local x = math.cos(angle) * radius
	local y = math.sin(angle) * radius

	star.Size = UDim2.new(0,2,0,2)
	star.Position = UDim2.new(0.5, x, 0.5, y)
	star.BackgroundColor3 = Color3.fromRGB(150,150,255)
	star.BorderSizePixel = 0
	star.Parent = galaxy
end

-- Rotación galaxia
task.spawn(function()
	while true do
		TweenService:Create(galaxy, TweenInfo.new(20, Enum.EasingStyle.Linear), {
			Rotation = galaxy.Rotation + 360
		}):Play()
		task.wait(20)
	end
end)

--// ✨ ESTRELLAS MEJORADAS -------------------
for i = 1,150 do
	local star = Instance.new("Frame")
	local size = math.random(1,4)

	star.Size = UDim2.new(0, size, 0, size)
	star.Position = UDim2.new(math.random(),0,math.random(),0)
	star.BackgroundColor3 = Color3.fromRGB(200,200,255)
	star.BorderSizePixel = 0
	star.Parent = background

	task.spawn(function()
		while true do
			-- Parpadeo
			TweenService:Create(star, TweenInfo.new(math.random(1,3)), {
				BackgroundTransparency = math.random()
			}):Play()

			-- Movimiento leve
			TweenService:Create(star, TweenInfo.new(math.random(5,10)), {
				Position = UDim2.new(math.random(),0,math.random(),0)
			}):Play()

			task.wait(math.random(2,4))
		end
	end)
end

