-- LIMPIADOR DEL CUADRITO ROJO Y GUI ANTIGUAS
local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Elimina todas las ScreenGui creadas por scripts
for _, gui in ipairs(playerGui:GetChildren()) do
	if gui:IsA("ScreenGui") then
		gui:Destroy()
	end
end

-- También limpia el Blur si quedó
local Lighting = game:GetService("Lighting")
for _, effect in ipairs(Lighting:GetChildren()) do
	if effect:IsA("BlurEffect") then
		effect:Destroy()
	end
end

-- Reactiva el sonido y la UI normal de Roblox
game:GetService("SoundService").Volume = 1
pcall(function()
	game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
end)

print("✅ Cuadrito rojo y GUIs antiguas eliminadas")
