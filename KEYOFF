-- Nebulosas ligeras
local function crearNebulosa(c1, c2, transparency, speed)
	local neb = Instance.new("Frame")
	neb.Size = UDim2.new(1.7, 0, 1.7, 0)
	neb.Position = UDim2.new(-0.35, 0, -0.35, 0)
	neb.BackgroundTransparency = 1
	neb.Parent = background

	local grad = Instance.new("UIGradient")
	grad.Color = ColorSequence.new{c1, c2}
	grad.Transparency = NumberSequence.new{transparency, 1}
	grad.Rotation = math.random(0, 360)
	grad.Parent = neb

	local tweenInfo = TweenInfo.new(speed, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1)
	
	task.spawn(function()
		while neb and neb.Parent do
			local pos = UDim2.new(math.random(-35, -10)/100, 0, math.random(-35, -10)/100, 0)
			TweenService:Create(neb, tweenInfo, {Position = pos}):Play()
			task.wait(speed * 0.75)
		end
	end)
end

crearNebulosa(Color3.fromRGB(55,0,110), Color3.fromRGB(0,95,145), 0.4, 52)
crearNebulosa(Color3.fromRGB(15,45,115), Color3.fromRGB(85,0,135), 0.5, 68)

