	end
end

--==================================================
-- LOOP
--==================================================

RunService.RenderStepped:Connect(function(dt)

	for _,p in ipairs(particles) do
		p.angle += p.speed

		local sin = math.sin(p.angle)
		local cos = math.cos(p.angle)

		local x = center.X + cos * p.radius
		local y = center.Y + sin * (p.radius * 0.35)

		local curve = -math.abs(sin)*6

		p.frame.Position = UDim2.fromOffset(x, y + curve)
	end

	lastBurst += dt
	if lastBurst >= BURST_INTERVAL then
		lastBurst = 0
		spawnBurst()
	end
end)

