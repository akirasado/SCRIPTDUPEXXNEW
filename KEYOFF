-- Música
local sound = Instance.new("Sound")
sound.SoundId = musicLoading
sound.Looped = true
sound.Volume = 1
sound.Parent = background
sound:Play()

-- Función de carga
local function runLoading(duration, color)
	local startTime = tick()
	bar.BackgroundColor3 = color
	glow.Color = color

	while true do
		local progress = math.clamp((tick() - startTime) / duration, 0, 1)
		bar.Size = UDim2.new(progress, 0, 1, 0)
		percent.Text = math.floor(progress * 100) .. "%"
		
		if progress >= 1 then break end
		task.wait(0.05)
	end
end

-- Ejecución principal
typeText(title, loadingText1)
runLoading(loadTime1, Color3.fromRGB(255, 30, 30))

bar.Size = UDim2.new(0, 0, 1, 0)

typeText(title, loadingText2)

sound:Stop()
sound.SoundId = musicInjecting
sound:Play()

runLoading(loadTime2, Color3.fromRGB(30, 255, 90))

-- Pantalla final (se queda mucho tiempo)
title.Text = "DUPEXX GALACTIC SCRIPT INJECTED SUCCESSFULLY"
percent.Text = "100% - FULLY LOADED"

