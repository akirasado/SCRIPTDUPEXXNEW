--==================================================
-- 💥 JETS (AMBOS POLOS)
--==================================================

local lastBurst = 0
local BURST_INTERVAL = 30

local function spawnJet(direction)
	local folder = Instance.new("Folder", bh)

	for i = 1,14 do
		local part = Instance.new("Frame")
		part.Size = UDim2.fromOffset(3,3)
		part.BackgroundColor3 = Color3.fromRGB(255,255,255)
		part.BorderSizePixel = 0
		part.Position = UDim2.fromOffset(center.X, center.Y)
		part.Parent = folder

		local spreadX = (math.random()-0.5)*20
		local speedY = math.random(50,80)/10 * direction

		task.spawn(function()
			local life = 0
			while life < 1 do
				life += 0.02

				local x = center.X + spreadX * life
				local y = center.Y + speedY * life * 20

				part.Position = UDim2.fromOffset(x,y)
				part.BackgroundTransparency = life

				task.wait()
			end
			part:Destroy()
		end)
	end

	task.delay(2, function()
		folder:Destroy()
	end)
end

local function spawnBurst()
	spawnJet(1)
	spawnJet(-1)
end

