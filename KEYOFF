-- porcentaje
local percent = Instance.new("TextLabel")
percent.Size = UDim2.fromScale(1,0.05)
percent.Position = UDim2.fromScale(0,0.62)
percent.BackgroundTransparency = 1
percent.TextColor3 = Color3.fromRGB(180,180,255)
percent.TextScaled = true
percent.Text = "0%"
percent.Parent = bg

-- loading fluido
local function runLoading(duration,color)
	bar.BackgroundColor3 = color
	glow.Color = color

	local start = tick()

	while true do
		local p = math.clamp((tick()-start)/duration,0,1)

		bar.Size = UDim2.new(p,0,1,0)
		percent.Text = math.floor(p*100).."%"

		if p >= 1 then break end
		task.wait()
	end
end

