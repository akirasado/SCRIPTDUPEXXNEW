--// CONFIG
local loadingText1 = "LOADING DUPEXX GALATIC SCRIPT"
local loadingText2 = "INJECTING DUPEXX GALACTIC SCRIPT"
local loadTime1 = 300
local loadTime2 = 180
local typingSpeed = 0.035

--// SERVICES
local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

--// GUI
local gui = Instance.new("ScreenGui", playerGui)
gui.IgnoreGuiInset = true

local bg = Instance.new("Frame", gui)
bg.Size = UDim2.fromScale(1,1)
bg.BackgroundColor3 = Color3.fromRGB(0,0,0)

-- Blur
Instance.new("BlurEffect", Lighting).Size = 15

--// 🌌 GALAXIA REALISTA
local galaxy = Instance.new("Frame", bg)
galaxy.Size = UDim2.fromOffset(220,220)
galaxy.Position = UDim2.fromScale(0.75,0.25)
galaxy.AnchorPoint = Vector2.new(0.5,0.5)
galaxy.BackgroundTransparency = 1

-- núcleo
for i = 1,40 do
	local s = Instance.new("Frame", galaxy)
	local size = math.random(2,5)
	s.Size = UDim2.fromOffset(size,size)
	s.Position = UDim2.fromOffset(math.random(-10,10),math.random(-10,10))
	s.AnchorPoint = Vector2.new(0.5,0.5)
	s.BackgroundColor3 = Color3.fromRGB(220,220,255)
	s.BackgroundTransparency = math.random(1,3)/10
	s.BorderSizePixel = 0
end

-- brazos espirales DOBLES
for arm = 0,1 do
	for i = 1,140 do
		local star = Instance.new("Frame", galaxy)

		local t = i/20
		local angle = t + (arm * math.pi)
		local radius = t * 6

		local x = math.cos(angle) * radius
		local y = math.sin(angle) * radius

		star.Size = UDim2.fromOffset(2,2)
		star.Position = UDim2.new(0.5, x, 0.5, y)
		star.BackgroundColor3 = Color3.fromRGB(180,180,255)
		star.BackgroundTransparency = 0.4 + (i/200)
		star.BorderSizePixel = 0
	end
end

-- rotación suave continua
task.spawn(function()
	while true do
		galaxy.Rotation += 0.02
		task.wait()
	end
end)

--// ⭐ ESTRELLAS SUAVES
local stars = {}

for i = 1,100 do
	local s = Instance.new("Frame", bg)
	local size = math.random(2,4)
	s.Size = UDim2.fromOffset(size,size)
	s.Position = UDim2.fromScale(math.random(),math.random())
	s.BackgroundColor3 = Color3.fromRGB(200,200,255)
	s.BackgroundTransparency = math.random(4,8)/10
	s.BorderSizePixel = 0
	table.insert(stars, s)
end

-- animación fluida SIN saltos
task.spawn(function()
	while true do
		for _,s in ipairs(stars) do
			local target = math.clamp(
				s.BackgroundTransparency + (math.random(-5,5)/100),
				0.3,0.9
			)

			TweenService:Create(s, TweenInfo.new(0.25), {
				BackgroundTransparency = target
			}):Play()
		end
		task.wait(0.2)
	end
end)

--// TEXTO
local title = Instance.new("TextLabel", bg)
title.Size = UDim2.fromScale(1,0.2)
title.Position = UDim2.fromScale(0,0.35)
title.BackgroundTransparency = 1
title.TextColor3 = Color3.fromRGB(170,0,255)
title.TextScaled = true
title.Font = Enum.Font.SourceSansBold

-- glow suave
local stroke = Instance.new("UIStroke", title)
stroke.Color = Color3.fromRGB(255,255,255)
stroke.Thickness = 1.5
stroke.Transparency = 0.4

task.spawn(function()
	while true do
		TweenService:Create(stroke, TweenInfo.new(1.5), {Transparency = 0.2}):Play()
		task.wait(1.5)
		TweenService:Create(stroke, TweenInfo.new(1.5), {Transparency = 0.6}):Play()
		task.wait(1.5)
	end
end)

-- typing
local function typeText(label,text)
	label.Text = ""
	for i=1,#text do
		label.Text = text:sub(1,i)
		task.wait(typingSpeed)
	end
end

--// BARRA BONITA (OVALADA)
local barBg = Instance.new("Frame", bg)
barBg.Size = UDim2.fromScale(0.6,0.05)
barBg.Position = UDim2.fromScale(0.2,0.55)
barBg.BackgroundColor3 = Color3.fromRGB(40,40,70)

local corner = Instance.new("UICorner", barBg)
corner.CornerRadius = UDim.new(1,0)

local bar = Instance.new("Frame", barBg)
bar.Size = UDim2.new(0,0,1,0)
bar.BackgroundColor3 = Color3.fromRGB(255,0,0)

local corner2 = Instance.new("UICorner", bar)
corner2.CornerRadius = UDim.new(1,0)

local glow = Instance.new("UIStroke", bar)
glow.Thickness = 2
glow.Color = bar.BackgroundColor3

-- porcentaje
local percent = Instance.new("TextLabel", bg)
percent.Size = UDim2.fromScale(1,0.05)
percent.Position = UDim2.fromScale(0,0.62)
percent.BackgroundTransparency = 1
percent.TextColor3 = Color3.fromRGB(180,180,255)
percent.TextScaled = true
percent.Text = "0%"

-- loading fluido real
local function runLoading(duration,color)
	bar.BackgroundColor3 = color
	glow.Color = color

	local start = tick()

	while true do
		local p = math.clamp((tick()-start)/duration,0,1)

		bar.Size = UDim2.new(p,0,1,0)
		percent.Text = math.floor(p*100).."%"

		if p >= 1 then break end
		task.wait()
	end
end

--// EJECUCIÓN
typeText(title, loadingText1)
runLoading(loadTime1, Color3.fromRGB(255,0,0))

bar.Size = UDim2.new(0,0,1,0)

typeText(title, loadingText2)
runLoading(loadTime2, Color3.fromRGB(0,255,100))
