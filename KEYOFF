-- Nebulosas ligeras (solo 2)
local function crearNebulosa(c1, c2, t, vel)
	local n = Instance.new("Frame")
	n.Size = UDim2.new(1.8,0,1.8,0)
	n.Position = UDim2.new(-0.4,0,-0.4,0)
	n.BackgroundTransparency = 1
	n.Parent = bg

	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new{c1, c2}
	g.Transparency = NumberSequence.new{t, 1}
	g.Rotation = math.random(0,360)
	g.Parent = n

	local ti = TweenInfo.new(vel, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1)
	task.spawn(function()
		while n and n.Parent do
			local pos = UDim2.new(math.random(-40,-5)/100,0,math.random(-40,-5)/100,0)
			TweenService:Create(n, ti, {Position = pos}):Play()
			task.wait(vel * 0.75)
		end
	end)
end

crearNebulosa(Color3.fromRGB(70,0,130), Color3.fromRGB(0,110,160), 0.35, 50)
crearNebulosa(Color3.fromRGB(20,60,130), Color3.fromRGB(100,0,160), 0.45, 70)

