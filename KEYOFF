--==================================================
-- 🌌 GALAXIA MEJORADA
--==================================================

local galaxy = Instance.new("Frame")
galaxy.Size = UDim2.fromOffset(220,220)
galaxy.Position = UDim2.fromScale(0.75,0.25)
galaxy.AnchorPoint = Vector2.new(0.5,0.5)
galaxy.BackgroundTransparency = 1
galaxy.Parent = bg

-- núcleo
for i = 1,50 do
	local s = Instance.new("Frame")
	s.Size = UDim2.fromOffset(math.random(2,4),math.random(2,4))
	s.Position = UDim2.new(0.5, (math.random()-0.5)*20, 0.5, (math.random()-0.5)*20)
	s.AnchorPoint = Vector2.new(0.5,0.5)
	s.BackgroundColor3 = Color3.fromRGB(220,220,255)
	s.BackgroundTransparency = math.random(1,4)/10
	s.BorderSizePixel = 0
	s.Parent = galaxy
end

-- brazos espirales
for arm = 0,1 do
	for i = 1,120 do
		local star = Instance.new("Frame")

		local t = i / 15
		local angle = t + (arm * math.pi)
		local radius = t * 5
		local noise = (math.random() - 0.5) * 3

		local x = math.cos(angle) * (radius + noise)
		local y = math.sin(angle) * (radius + noise)

		star.Size = UDim2.fromOffset(2,2)
		star.Position = UDim2.new(0.5, x, 0.5, y)
		star.BackgroundColor3 = Color3.fromRGB(180,180,255)
		star.BackgroundTransparency = 0.4 + (i/180)
		star.BorderSizePixel = 0
		star.Parent = galaxy
	end
end

-- rotación suave
RunService.RenderStepped:Connect(function(dt)
	galaxy.Rotation += dt * 2
end)

--==================================================
-- ⭐ ESTRELLAS (SIN DUPLICADOS)
--==================================================

local stars = {}

for i = 1,100 do
	local s = Instance.new("Frame")

	local x = math.random(0,1000)/1000
	local y = math.random(0,1000)/1000

	s.Size = UDim2.fromOffset(math.random(2,4),math.random(2,4))
	s.Position = UDim2.fromScale(x,y)
	s.BackgroundColor3 = Color3.fromRGB(200,200,255)
	s.BackgroundTransparency = math.random(4,8)/10
	s.BorderSizePixel = 0
	s.Parent = bg

	table.insert(stars, s)
end

-- fade suave
task.spawn(function()
	while true do
		for _,s in ipairs(stars) do
			local target = math.random(30,90)/100

			TweenService:Create(s, TweenInfo.new(0.4), {
				BackgroundTransparency = target
			}):Play()
		end
		task.wait(0.2)
	end
end)

